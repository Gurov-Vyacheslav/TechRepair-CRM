@page "{orderId:int}/{serviceId:int}/{partId:int}"
@model TechRepair_CRM.Pages.Orders.EditServicePartModel

@{
    ViewData["Title"] = "Изменить деталь услуги";
}

<h1>Изменить деталь услуги</h1>

<div class="form-page">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="form-field">
            <label asp-for="Input.Quantity" class="form-label"></label>
            <input asp-for="Input.Quantity" class="form-control form-control-sm" />
            <span asp-validation-for="Input.Quantity" class="validation-message"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Сохранить</button>
            <a asp-page="/Orders/Details" asp-route-id="@Model.OrderId" class="btn btn-secondary">Назад</a>
        </div>
    </form>
</div>