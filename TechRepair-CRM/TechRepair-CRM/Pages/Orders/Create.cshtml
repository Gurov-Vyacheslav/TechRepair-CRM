@page
@model TechRepair_CRM.Pages.Orders.CreateModel

@{
    ViewData["Title"] = "Создать заказ";
}

<h1>Создать заказ</h1>

<div class="form-page">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="form-field">
            <label asp-for="Input.DeviceId" class="form-label"></label>
            <select asp-for="Input.DeviceId" asp-items="Model.Devices" class="form-control">
                <option value="">Выберите устройство</option>
            </select>
            <span asp-validation-for="Input.DeviceId" class="validation-message"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.ProblemDescription" class="form-label"></label>
            <textarea asp-for="Input.ProblemDescription" class="form-control"></textarea>
            <span asp-validation-for="Input.ProblemDescription" class="validation-message"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.EstimatedCost" class="form-label"></label>
            <input asp-for="Input.EstimatedCost" class="form-control form-control-sm" />
            <span asp-validation-for="Input.EstimatedCost" class="validation-message"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.WarrantyMonths" class="form-label"></label>
            <input asp-for="Input.WarrantyMonths" class="form-control form-control-sm" />
            <span asp-validation-for="Input.WarrantyMonths" class="validation-message"></span>
        </div>

        <div class="checkbox-field">
            <input asp-for="Input.IsWarrantyRepair" />
            <label asp-for="Input.IsWarrantyRepair"></label>
        </div>

        <div class="form-field">
            <label asp-for="Input.DiagnosticResult" class="form-label"></label>
            <textarea asp-for="Input.DiagnosticResult" class="form-control"></textarea>
            <span asp-validation-for="Input.DiagnosticResult" class="validation-message"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.Notes" class="form-label"></label>
            <textarea asp-for="Input.Notes" class="form-control"></textarea>
            <span asp-validation-for="Input.Notes" class="validation-message"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Создать заказ</button>
            <a asp-page="/Orders/Index" class="btn btn-secondary">Отмена</a>
        </div>
    </form>
</div>