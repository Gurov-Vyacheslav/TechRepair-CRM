@page "{orderId:int}/{serviceId:int}"
@model TechRepair_CRM.Pages.Orders.AddServicePartModel

@{
    ViewData["Title"] = "Добавить деталь к услуге";
}

<h1>Добавить деталь к услуге</h1>

@if (TempData["Success"] is not null)
{
    <div class="message-success">@TempData["Success"]</div>
}

<div class="form-page">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="form-field">
            <label asp-for="Input.PartId" class="form-label"></label>
            <select asp-for="Input.PartId" asp-items="Model.Parts" class="form-control">
                <option value="">Выберите деталь</option>
            </select>
            <span asp-validation-for="Input.PartId" class="validation-message"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.Quantity" class="form-label"></label>
            <input asp-for="Input.Quantity" class="form-control form-control-sm" />
            <span asp-validation-for="Input.Quantity" class="validation-message"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Добавить деталь</button>
            <a asp-page="/Orders/Details" asp-route-id="@Model.OrderId" class="btn btn-secondary">К заказу</a>
        </div>
    </form>
</div>