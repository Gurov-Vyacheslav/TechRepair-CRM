@page
@model TechRepair_CRM.Pages.Orders.IndexModel

@{
    ViewData["Title"] = "Заказы";
}

<h1>Заказы</h1>

<div class="actions">
    <a asp-page="/Orders/Create" class="btn btn-primary">Создать заказ</a>
</div>

<form method="get" class="status-form">
    <div class="form-field">
        <label asp-for="Filter.OrderNumber" class="form-label">Номер заказа</label>
        <input asp-for="Filter.OrderNumber" class="form-control"/>
    </div>
    <div class="form-field">
        <label asp-for="Filter.Status" class="form-label">Статус</label>
        <select asp-for="Filter.Status" asp-items="Model.Statuses" class="form-control">
            <option value="">Все статусы</option>
        </select>
    </div>
    <div class="form-field">
        <label asp-for="Filter.ClientPhone" class="form-label">Телефон клиента</label>
        <input asp-for="Filter.ClientPhone" class="form-control"/>
    </div>
    <div class="form-field">
        <label asp-for="Filter.CreatedFrom" class="form-label">Дата создания От</label>
        <input asp-for="Filter.CreatedFrom" class="form-control form-control-sm" type="date"/>
    </div>
    <div class="form-field">
        <label asp-for="Filter.CreatedTo" class="form-label">Дата создания До</label>
        <input asp-for="Filter.CreatedTo" class="form-control form-control-sm" type="date"/>
    </div>
    <div class="form-field">
        <label asp-for="Filter.TechnicianId" class="form-label">Мастер</label>
        <select asp-for="Filter.TechnicianId" asp-items="Model.Technicians" class="form-control">
            <option value="">Все</option>
        </select>
    </div>
    <div class="form-field">
        <label asp-for="Filter.DeviceTypeId" class="form-label">Тип устройства</label>
        <select asp-for="Filter.DeviceTypeId" asp-items="Model.DeviceTypes" class="form-control">
            <option value="">Все</option>
        </select>
    </div>
    <div class="form-field">
        <label asp-for="Filter.HasDebt" class="form-label">Задолженность</label>
        <select asp-for="Filter.HasDebt" class="form-control">
            <option value="">Все</option>
            <option value="true">Есть долг</option>
            <option value="false">Без долга</option>
        </select>
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-secondary">Найти</button>
        <a asp-page="/Orders/Index" class="btn btn-secondary">Сбросить</a>
    </div>
</form>

@if (Model.Orders.Count == 0)
{
    <p>Заказов пока нет.</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>Номер</th>
            <th>Дата</th>
            <th>Статус</th>
            <th>Клиент</th>
            <th>Телефон</th>
            <th>Устройство</th>
            <th>Стоимость</th>
            <th>Оплачено</th>
            <th>Остаток</th>
            <th>Действия</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var order in Model.Orders)
        {
            <tr>
                <td>@order.OrderNumber</td>
                <td>@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@order.OrderStatus</td>
                <td>@order.ClientFullName</td>
                <td>@order.ClientPhone</td>
                <td>@order.DeviceType @order.Brand @order.Model</td>
                <td>@order.TotalCost</td>
                <td>@order.PaidAmount</td>
                <td>@order.RemainingAmount</td>
                <td>
                    <a asp-page="/Orders/Details"
                       asp-route-id="@order.OrderId"
                       class="btn btn-small btn-secondary">
                        Открыть
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}