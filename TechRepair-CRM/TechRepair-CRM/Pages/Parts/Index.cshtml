@page
@model TechRepair_CRM.Pages.Parts.IndexModel

@{
    ViewData["Title"] = "Детали";
}

<h1>Детали</h1>

<div class="actions">
    <a asp-page="/Parts/Create" class="btn btn-primary">Добавить деталь</a>
</div>

<div class="filter-panel">
    <form method="get">
        <div class="filter-grid">
            <div class="form-field">
                <label asp-for="Filter.Search" class="form-label">Поиск</label>
                <input asp-for="Filter.Search" class="form-control" />
            </div>

            <div class="form-field">
                <label asp-for="Filter.IsActive" class="form-label">Активность</label>
                <select asp-for="Filter.IsActive" class="form-control">
                    <option value="">Все</option>
                    <option value="true">Активные</option>
                    <option value="false">Неактивные</option>
                </select>
            </div>
        </div>

        <div class="filter-actions">
            <button type="submit" class="btn btn-secondary">Найти</button>
            <a asp-page="/Parts/Index" class="btn btn-secondary">Сбросить</a>
        </div>
    </form>
</div>

@if (Model.Parts.Count == 0)
{
    <p>Деталей пока нет.</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>Артикул</th>
            <th>Название</th>
            <th>Производитель</th>
            <th>Цена</th>
            <th>Активна</th>
            <th>Действия</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var part in Model.Parts)
        {
            <tr>
                <td>@part.PartNumber</td>
                <td>@part.PartName</td>
                <td>@part.Manufacturer</td>
                <td>@part.DefaultPrice</td>
                <td>@(part.IsActive ? "Да" : "Нет")</td>
                <td>
                    <a asp-page="/Parts/Edit"
                       asp-route-id="@part.PartId"
                       class="btn btn-small btn-primary">
                        Изменить
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}