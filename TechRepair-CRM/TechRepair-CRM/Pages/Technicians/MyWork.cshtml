@page
@model TechRepair_CRM.Pages.Technicians.MyWorkModel

@{
    ViewData["Title"] = "Мои работы";
}

<h1>Мои работы</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="message-error">
        @Model.ErrorMessage
    </div>

    <p>
        Эта страница доступна только пользователям, которые привязаны к мастеру.
    </p>

    return;
}

@if (TempData["Success"] is not null)
{
    <div class="message-success">@TempData["Success"]</div>
}

@if (TempData["Error"] is not null)
{
    <div class="message-error">@TempData["Error"]</div>
}

<div class="filter-panel">
    <form method="get">
        <label>
            <input asp-for="OnlyActive" />
            Показывать только активные незавершённые работы
        </label>

        <div class="filter-actions">
            <button type="submit" class="btn btn-secondary">Применить</button>
            <a asp-page="/Technician/MyWork" asp-route-onlyActive="false" class="btn btn-secondary">Показать все</a>
        </div>
    </form>
</div>

@if (Model.Items.Count == 0)
{
    <p>Назначенных работ нет.</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>Заказ</th>
            <th>Дата</th>
            <th>Статус</th>
            <th>Клиент</th>
            <th>Устройство</th>
            <th>Услуга</th>
            <th>Количество</th>
            <th>Сумма</th>
            <th>Завершена</th>
            <th>Действия</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.OrderNumber</td>
                <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    <span class="status-badge status-@item.OrderStatus.ToLower()">
                        @item.OrderStatus
                    </span>
                </td>
                <td>
                    @item.ClientFullName<br />
                    <small>@item.ClientPhone</small>
                </td>
                <td>@item.DeviceType @item.Brand @item.Model</td>
                <td>@item.ServiceName</td>
                <td>@item.Quantity</td>
                <td>@item.TotalPrice</td>
                <td>@(item.CompletedAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                <td>
                    <a asp-page="/Orders/Details"
                       asp-route-id="@item.OrderId"
                       class="btn btn-small btn-secondary">
                        Открыть заказ
                    </a>

                    @if (item.CompletedAt is null && item.OrderStatus == "InRepair")
                    {
                        <form method="post"
                              asp-page-handler="Complete"
                              asp-route-orderId="@item.OrderId"
                              asp-route-serviceId="@item.ServiceId"
                              style="display:inline">
                            <button type="submit" class="btn btn-small btn-primary">
                                Завершить
                            </button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
