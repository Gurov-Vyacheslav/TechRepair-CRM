@page
@model TechRepair_CRM.Pages.Technicians.IndexModel

@{
    ViewData["Title"] = "Мастера";
}

<h1>Мастера</h1>

<div class="actions">
    <a asp-page="/Technicians/Create" class="btn btn-primary">Добавить мастера</a>
</div>

<div class="filter-panel">
    <form method="get">
        <div class="filter-grid">
            <div class="form-field">
                <label asp-for="Filter.Search" class="form-label">Поиск</label>
                <input asp-for="Filter.Search" class="form-control" />
            </div>

            <div class="form-field">
                <label asp-for="Filter.IsActive" class="form-label">Активность</label>
                <select asp-for="Filter.IsActive" class="form-control">
                    <option value="">Все</option>
                    <option value="true">Активные</option>
                    <option value="false">Неактивные</option>
                </select>
            </div>
        </div>

        <div class="filter-actions">
            <button type="submit" class="btn btn-secondary">Найти</button>
            <a asp-page="/Technicians/Index" class="btn btn-secondary">Сбросить</a>
        </div>
    </form>
</div>

@if (Model.Technicians.Count == 0)
{
    <p>Мастеров пока нет.</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>ФИО</th>
            <th>Email</th>
            <th>Телефон</th>
            <th>Специализация</th>
            <th>Активен</th>
            <th>Действия</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var technician in Model.Technicians)
        {
            <tr>
                <td>@technician.LastName @technician.FirstName</td>
                <td>@technician.Email</td>
                <td>@technician.Phone</td>
                <td>@technician.Specialization</td>
                <td>@(technician.IsActive ? "Да" : "Нет")</td>
                <td>
                    <a asp-page="/Technicians/Details"
                       asp-route-id="@technician.TechnicianId"
                       class="btn btn-small btn-secondary">
                        Открыть
                    </a>

                    <a asp-page="/Technicians/Edit"
                       asp-route-id="@technician.TechnicianId"
                       class="btn btn-small btn-primary">
                        Изменить
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}