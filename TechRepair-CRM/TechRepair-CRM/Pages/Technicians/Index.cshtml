@page
@model TechRepair_CRM.Pages.Technicians.IndexModel

@{
    ViewData["Title"] = "Мастера";
}

<h1>Мастера</h1>

<div class="actions">
    <a asp-page="/Technicians/Create" class="btn btn-primary">Добавить мастера</a>
</div>

@if (Model.Technicians.Count == 0)
{
    <p>Мастеров пока нет.</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>ФИО</th>
            <th>Email</th>
            <th>Телефон</th>
            <th>Специализация</th>
            <th>Активен</th>
            <th>Действия</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var technician in Model.Technicians)
        {
            <tr>
                <td>@technician.LastName @technician.FirstName</td>
                <td>@technician.Email</td>
                <td>@technician.Phone</td>
                <td>@technician.Specialization</td>
                <td>@(technician.IsActive ? "Да" : "Нет")</td>
                <td>
                    <a asp-page="/Technicians/Edit"
                       asp-route-id="@technician.TechnicianId"
                       class="btn btn-small">
                        Изменить
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}