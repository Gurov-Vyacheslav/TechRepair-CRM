@page
@model TechRepair_CRM.Pages.Technicians.MyOrdersModel

@{
    ViewData["Title"] = "Мои заказы";
}

<h1>Мои заказы</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="message-error">
        @Model.ErrorMessage
    </div>

    <p>
        Эта страница доступна только пользователям, которые привязаны к мастеру.
    </p>

    return;
}

<div class="filter-panel">
    <form method="get">
        <label>
            <input asp-for="OnlyActive" />
            Показывать только активные заказы
        </label>

        <div class="filter-actions">
            <button type="submit" class="btn btn-secondary">Применить</button>
            <a asp-page="/Technician/MyOrders" asp-route-onlyActive="false" class="btn btn-secondary">
                Показать все
            </a>
        </div>
    </form>
</div>

@if (Model.Orders.Count == 0)
{
    <p>Прикреплённых заказов нет.</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>Номер</th>
            <th>Дата</th>
            <th>Статус</th>
            <th>Клиент</th>
            <th>Телефон</th>
            <th>Устройство</th>
            <th>Стоимость</th>
            <th>Остаток</th>
            <th>Действия</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var order in Model.Orders)
        {
            <tr>
                <td>@order.OrderNumber</td>
                <td>@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    <span class="status-badge status-@order.OrderStatus.ToLower()">
                        @order.OrderStatus
                    </span>
                </td>
                <td>@order.ClientFullName</td>
                <td>@order.ClientPhone</td>
                <td>@order.DeviceType @order.Brand @order.Model</td>
                <td>@order.TotalCost</td>
                <td>@order.RemainingAmount</td>
                <td>
                    <a asp-page="/Orders/Details"
                       asp-route-id="@order.OrderId"
                       class="btn btn-small btn-secondary">
                        Открыть
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}