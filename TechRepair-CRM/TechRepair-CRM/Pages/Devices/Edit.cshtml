@page "{id:int}"
@model TechRepair_CRM.Pages.Devices.EditModel

@{
    ViewData["Title"] = "Изменить устройство";
}

<h1>Изменить устройство</h1>

<div class="form-page">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
        <div class="form-field"><label asp-for="Input.DeviceTypeId" class="form-label"></label><select asp-for="Input.DeviceTypeId" asp-items="Model.DeviceTypes" class="form-control"><option value="">Выберите тип устройства</option></select><span asp-validation-for="Input.DeviceTypeId" class="validation-message"></span></div>
        <div class="form-field"><label asp-for="Input.Brand" class="form-label"></label><input asp-for="Input.Brand" class="form-control" /></div>
        <div class="form-field"><label asp-for="Input.Model" class="form-label"></label><input asp-for="Input.Model" class="form-control" /></div>
        <div class="form-field"><label asp-for="Input.SerialNumber" class="form-label"></label><input asp-for="Input.SerialNumber" class="form-control" /></div>
        <div class="form-field"><label asp-for="Input.PurchaseDate" class="form-label"></label><input asp-for="Input.PurchaseDate" class="form-control form-control-sm" /></div>
        <div class="form-field"><label asp-for="Input.EquipmentDescription" class="form-label"></label><textarea asp-for="Input.EquipmentDescription" class="form-control"></textarea></div>
        <div class="form-field"><label asp-for="Input.ExternalCondition" class="form-label"></label><textarea asp-for="Input.ExternalCondition" class="form-control"></textarea></div>
        <div class="form-field"><label asp-for="Input.Notes" class="form-label"></label><textarea asp-for="Input.Notes" class="form-control"></textarea></div>
        <div class="form-actions"><button type="submit" class="btn btn-primary">Сохранить</button><a asp-page="/Clients/Index" class="btn btn-secondary">Отмена</a></div>
    </form>
</div>