@page
@model TechRepair_CRM.Pages.DeviceTypes.IndexModel
@{ ViewData["Title"] = "Типы устройств"; }
<h1>Типы устройств</h1>
@if (TempData["Success"] is not null) { <div class="message-success">@TempData["Success"]</div> }
@if (TempData["Error"] is not null) { <div class="message-error">@TempData["Error"]</div> }
<div class="actions"><a asp-page="/DeviceTypes/Create" class="btn btn-primary">Добавить тип устройства</a></div>
@if (Model.DeviceTypes.Count == 0) { <p>Типы устройств ещё не добавлены.</p> }
else {
    <table><thead><tr><th>ID</th><th>Название</th><th>Действия</th></tr></thead><tbody>
        @foreach (var type in Model.DeviceTypes) {
            <tr><td>@type.DeviceTypeId</td><td>@type.TypeName</td><td>
                <a asp-page="/DeviceTypes/Edit" asp-route-id="@type.DeviceTypeId" class="btn btn-small btn-primary">Изменить</a>
                <form method="post" asp-page-handler="Delete" asp-route-id="@type.DeviceTypeId" style="display:inline" onsubmit="return confirm('Удалить тип устройства? Это возможно только если он нигде не используется.');">
                    <button type="submit" class="btn btn-small btn-danger">Удалить</button></form>
            </td></tr> }
        </tbody></table> }