@page
@model TechRepair_CRM.Pages.Admin.Users.CreateModel

@{
    ViewData["Title"] = "Создать пользователя";
}

<h1>Создать пользователя</h1>

<div class="form-page">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="form-field">
            <label asp-for="Input.Email" class="form-label"></label>
            <input asp-for="Input.Email" class="form-control" id="emailInput" />
            <span asp-validation-for="Input.Email" class="validation-message"></span>
            <small id="emailHint">
                Для роли Technician email будет взят из карточки выбранного мастера.
            </small>
        </div>

        <div class="form-field">
            <label asp-for="Input.Password" class="form-label"></label>
            <input asp-for="Input.Password" type="password" class="form-control" />
            <span asp-validation-for="Input.Password" class="validation-message"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.Role" class="form-label"></label>
            <select asp-for="Input.Role" asp-items="Model.Roles" class="form-control" id="roleSelect">
                <option value="">Выберите роль</option>
            </select>
            <span asp-validation-for="Input.Role" class="validation-message"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.TechnicianId" class="form-label"></label>

            <select asp-for="Input.TechnicianId" class="form-control" id="technicianSelect">
                <option value="" data-email="">Не привязан к мастеру</option>

                @foreach (var technician in Model.Technicians)
                {
                    <option value="@technician.TechnicianId"
                            data-email="@technician.Email">
                        @technician.FullName — @technician.Email
                    </option>
                }
            </select>

            <span asp-validation-for="Input.TechnicianId" class="validation-message"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Создать</button>
            <a asp-page="/Admin/Users/Index" class="btn btn-secondary">Отмена</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/admin-user-form.js" asp-append-version="true"></script>
}