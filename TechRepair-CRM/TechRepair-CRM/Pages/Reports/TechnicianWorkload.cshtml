@page
@model TechRepair_CRM.Pages.Reports.TechnicianWorkloadModel

@{
    ViewData["Title"] = "Загрузка мастеров";
}

<h1>Загрузка мастеров</h1>

<p>
    <a asp-page="/Reports/Index" class="btn btn-secondary">Назад к отчётам</a>
</p>

@if (Model.Items.Count == 0)
{
    <p>Данных пока нет.</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>Мастер</th>
            <th>Специализация</th>
            <th>Активен</th>
            <th>Назначено строк услуг</th>
            <th>Назначено всего услуг</th>
            <th>Завершено всего услуг</th>
            <th>Стоимость назначенных услуг</th>
            <th>Стоимость завершённых услуг</th>
            <th>Первое завершение</th>
            <th>Последнее завершение</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@(item.Specialization ?? "—")</td>
                <td>@(item.IsActive ? "Да" : "Нет")</td>
                <td>@item.AssignedServiceRowsCount</td>
                <td>@item.AssignedServiceQuantity</td>
                <td>@item.CompletedServiceQuantity</td>
                <td>@item.AssignedServiceAmount</td>
                <td>@item.CompletedServiceAmount</td>
                <td>@(item.FirstCompletedAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                <td>@(item.LastCompletedAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
            </tr>
        }
        </tbody>
    </table>
}