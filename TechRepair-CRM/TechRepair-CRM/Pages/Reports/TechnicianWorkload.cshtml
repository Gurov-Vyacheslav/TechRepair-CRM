@page
@model TechRepair_CRM.Pages.Reports.TechnicianWorkloadModel

@{
    ViewData["Title"] = "Загрузка мастеров";
}

<h1>Загрузка мастеров</h1>

<p>
    <a asp-page="/Reports/Index" class="btn btn-secondary">Назад к отчётам</a>
</p>

<p class="text-muted">Назначено строк услуг — количество позиций order_service. Количество с учётом quantity — сумма количества по назначенным услугам. Стоимость назначенных услуг — сумма quantity × price_at_moment.</p>

@if (Model.Items.Count == 0)
{
    <p>Данных пока нет.</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>Мастер</th>
            <th>Специализация</th>
            <th>Активен</th>
            <th>Назначено строк услуг</th>
            <th>Завершено услуг</th>
            <th>Количество с учётом quantity</th>
            <th>Стоимость назначенных услуг</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.LastName @item.FirstName</td>
                <td>@item.Specialization</td>
                <td>@(item.IsActive ? "Да" : "Нет")</td>
                <td>@item.AssignedServicesCount</td>
                <td>@item.CompletedServicesCount</td>
                <td>@item.TotalServiceQuantity</td>
                <td>@item.TotalServiceAmount</td>
            </tr>
        }
        </tbody>
    </table>
}