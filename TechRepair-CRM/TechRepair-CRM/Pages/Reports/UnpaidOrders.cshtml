@page
@model TechRepair_CRM.Pages.Reports.UnpaidOrdersModel

@{
    ViewData["Title"] = "Неоплаченные заказы";
}

<h1>Неоплаченные заказы</h1>

<p>
    <a asp-page="/Reports/Index" class="btn btn-secondary">Назад к отчётам</a>
</p>

@if (Model.Orders.Count == 0)
{
    <p>Неоплаченных заказов нет.</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>Номер</th>
            <th>Дата</th>
            <th>Статус</th>
            <th>Клиент</th>
            <th>Телефон</th>
            <th>Устройство</th>
            <th>Гарантия</th>
            <th>Стоимость</th>
            <th>Оплачено</th>
            <th>Остаток</th>
            <th>Действия</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var order in Model.Orders)
        {
            <tr>
                <td>@order.OrderNumber</td>
                <td>@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@order.OrderStatus</td>
                <td>@order.ClientFullName</td>
                <td>@order.ClientPhone</td>
                <td>@order.DeviceType @order.Brand @order.Model</td>
                <td>@(order.IsWarrantyRepair ? "Да" : "Нет")</td>
                <td>@order.TotalCost</td>
                <td>@order.PaidAmount</td>
                <td>@order.RemainingAmount</td>
                <td>
                    <a asp-page="/Orders/Details"
                       asp-route-id="@order.OrderId"
                       class="btn btn-small btn-secondary">
                        Открыть
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}