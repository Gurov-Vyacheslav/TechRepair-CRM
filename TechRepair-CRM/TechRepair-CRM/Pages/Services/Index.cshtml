@page
@model TechRepair_CRM.Pages.Services.IndexModel

@{
    ViewData["Title"] = "Услуги";
}

<h1>Услуги</h1>

<div class="actions">
    <a asp-page="/Services/Create" class="btn btn-primary">Добавить услугу</a>
</div>

<div class="filter-panel">
    <form method="get">
        <div class="filter-grid">
            <div class="form-field">
                <label asp-for="Filter.Search" class="form-label">Поиск</label>
                <input asp-for="Filter.Search" class="form-control" />
            </div>

            <div class="form-field">
                <label asp-for="Filter.IsActive" class="form-label">Активность</label>
                <select asp-for="Filter.IsActive" class="form-control">
                    <option value="">Все</option>
                    <option value="true">Активные</option>
                    <option value="false">Неактивные</option>
                </select>
            </div>
        </div>

        <div class="filter-actions">
            <button type="submit" class="btn btn-secondary">Найти</button>
            <a asp-page="/Services/Index" class="btn btn-secondary">Сбросить</a>
        </div>
    </form>
</div>
@if (Model.Services.Count == 0)
{
    <p>Услуг пока нет.</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>Название</th>
            <th>Описание</th>
            <th>Цена</th>
            <th>Длительность</th>
            <th>Активна</th>
            <th>Действия</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var service in Model.Services)
        {
            <tr>
                <td>@service.ServiceName</td>
                <td>@service.Description</td>
                <td>@service.BasePrice</td>
                <td>@service.EstimatedDuration</td>
                <td>@(service.IsActive ? "Да" : "Нет")</td>
                <td>
                    <a asp-page="/Services/Edit"
                       asp-route-id="@service.ServiceId"
                       class="btn btn-small btn-primary">
                        Изменить
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}