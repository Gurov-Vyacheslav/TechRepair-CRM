@using TechRepair_CRM.Services.Layout
@inject ILayoutUserContextService LayoutUserContextService

@{
    var layoutUser = await LayoutUserContextService.GetAsync();
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - TechRepair CRM</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<header class="topbar">
    <div class="topbar__brand">
        <span>TechRepair CRM</span>
    </div>

    <nav class="topbar__nav">
        @if (layoutUser.CanManageSystem)
        {
            <a asp-page="/Orders/Index">Заказы</a>
            <a asp-page="/Clients/Index">Клиенты</a>
            <a asp-page="/Services/Index">Услуги</a>
            <a asp-page="/Parts/Index">Детали</a>
            <a asp-page="/Technicians/Index">Мастера</a>
            <a asp-page="/Reports/Index">Отчёты</a>
        }

        @if (layoutUser.CanShowMyWork)
        {
            <a asp-page="/Technicians/MyWork">Мои работы</a>
            <a asp-page="/Technicians/MyOrders">Мои заказы</a>
        }

        @if (layoutUser.CanShowAdminPanel)
        {
            <a asp-page="/Admin/Users/Index">Администрирование</a>
        }
    </nav>

    <div class="topbar__user">
        @if (layoutUser.IsAuthenticated)
        {
            <span>@layoutUser.UserName</span>

            <form method="post" asp-page="/Account/Logout" class="logout-form">
                <button type="submit" class="btn btn-secondary btn-small">Выйти</button>
            </form>
        }
    </div>
</header>

<main class="page">
    @RenderBody()
</main>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>